# Firebase Web app config — Firebase Console → Project Settings → General → "Your apps" → Web app
# Copy this file to .env and fill in your project's values. .env is gitignored, never commit real values.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Supabase project config — Supabase Dashboard → Settings → API
# Project URL and anon/public key. .env is gitignored, never commit real values.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
